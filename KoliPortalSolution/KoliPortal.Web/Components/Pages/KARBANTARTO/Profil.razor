@page "/profil"
@using KoliPortal.Lib.MODEL
@using KoliPortal.Lib.SERVICE
@using System.Security.Claims
@using System.IdentityModel.Tokens.Jwt
@layout KarbantartoLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject FelhasznalokService FelhasznaloService
@inject SzerepkorokService SzerepkorokService
@inject IJSRuntime JS
@inject NavigationManager Nav

@if (betoltesAlatt)
{
	<div class="text-center mt-5">
		<div class="spinner-border text-primary" role="status">
			<span class="visually-hidden">Betöltés...</span>
		</div>
		<p class="mt-2 text-muted">Adataid betöltése...</p>
	</div>
}
else if (!string.IsNullOrEmpty(hibaUzenet))
{
	<div class="alert alert-danger m-3">
		<i class="bi bi-exclamation-triangle-fill"></i> @hibaUzenet
	</div>
}
else if (sajatUser != null)
{
	<div id="view-profile" class="view-section active">
		<div class="section-header" style="text-align: left; margin-bottom: 2rem;">
			<h2>Saját Adataim</h2>
			<p>Személyes információk.</p>
		</div>
		<div class="content-panel">
			<div class="input-group">
				<label>Név</label>
				<input type="text" class="input-field" value="@sajatUser.Nev" readonly>
			</div>

			<div class="input-group">
				<label>Beosztás</label>
				<input type="text" class="input-field" value="@szerepkorNev" readonly>
			</div>

			<div class="input-group">
				<label>E-mail cím</label>
				<input type="text" class="input-field" value="@sajatUser.Email" readonly>
			</div>
		</div>
	</div>
}

@code {
	private string token = "";
	private bool betoltesAlatt = true;
	private string hibaUzenet = "";
	private int sajatId = 0;

	// Itt tároljuk a lekérdezett adatokat
	private KoliPortal.Lib.MODEL.Felhasznalok sajatUser;
	private string szerepkorNev = "";

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			try
			{
				// Token ellenőrzése
				token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

				if (string.IsNullOrEmpty(token))
				{
					Nav.NavigateTo("/");
					return;
				}

				// JWT dekódolása és azonosító kinyerése
				var handler = new JwtSecurityTokenHandler();
				var jwtToken = handler.ReadJwtToken(token);

				var idClaim = jwtToken.Claims.FirstOrDefault(x =>
				  x.Type == ClaimTypes.NameIdentifier ||
				  x.Type == "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier");

				if (idClaim != null && int.TryParse(idClaim.Value, out int parsedId))
				{
					sajatId = parsedId;
				}
				else
				{
					hibaUzenet = "Nem sikerült azonosítani a felhasználót a tokenből.";
					betoltesAlatt = false;
					StateHasChanged();
					return;
				}

				// Saját adatok lekérése a szerverről
				var osszesUser = await FelhasznaloService.GetFelhasznalok(token) ?? new();
				sajatUser = osszesUser.FirstOrDefault(u => u.ID == sajatId);

				// Szerepkör nevének lekérése 
				var szerepkorok = await SzerepkorokService.GetSzerepkorok(token) ?? new();
				var szerep = szerepkorok.FirstOrDefault(r => r.ID == sajatUser.SzerepkorID);
				szerepkorNev = szerep != null ? szerep.Nev : "Ismeretlen beosztás";

			}
			catch (Exception ex)
			{
				hibaUzenet = $"Hiba a profil betöltésekor: {ex.Message}";
			}
			finally
			{
				betoltesAlatt = false;
				StateHasChanged();
			}
		}
	}
}