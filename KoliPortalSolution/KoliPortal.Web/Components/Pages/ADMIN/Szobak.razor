                    </td>
                </tr>
                <tr>
                    <td>102</td>
                    <td>1. Emelet</td>
                    <td>3 fő</td>
                    <td>Szabó P., Varga J., Kiss M.</td>
                    <td>
                        <span class="status-badge full">100% (3/3)</span>
                    </td>
                </tr>
                <tr>
                    <td>205</td>
                    <td>2. Emelet</td>
                    <td>2 fő</td>
