@page "/beallitasok"
@using KoliPortal.Lib.MODEL
@using KoliPortal.Lib.SERVICE
@using System.IdentityModel.Tokens.Jwt
@layout AdminLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject PenzugyekService Penzugyek
@inject SzobaBeosztasokService SzobaBeosztasok
@inject FizetesTipusokService FizetesTipusok
@inject IJSRuntime JS
@inject NavigationManager Nav

<header class="page-header text-center">
    <h1>Rendszerbeállítások és Pénzügyek</h1>
    <p>A kollégiumi díjak tömeges kiírása és globális beállítások.</p>
</header>

@if (betoltesAlatt)
{
    <div class="text-center mt-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Betöltés...</span>
        </div>
        <p class="mt-2 text-muted">Rendszer előkészítése...</p>
    </div>
}
else
{
    <div class="content-wrapper" style="max-width: 600px; margin: 0 auto;">

        @if (sikeresMentes)
        {
            <div class="alert alert-success mb-4">
                <i class="bi bi-check-circle-fill"></i> <strong>Siker:</strong> @sikerUzenet
            </div>
        }
        @if (!string.IsNullOrEmpty(hibaUzenet))
        {
            <div class="alert alert-danger mb-4">
                <i class="bi bi-exclamation-triangle-fill"></i> @hibaUzenet
            </div>
        }

        <div class="settings-grid">

            <div class="card settings-card">
                <div class="card-header">
                    <h2><i class="bi bi-building"></i> Díjak és Terhelések</h2>
                </div>
                <div class="settings-form">
                    
                    @* TÍPUS KIVÁLASZTÁSA - Az opciók objektumból jönnek, alapértelmezett kivalasztottTipusId = 1 *@
                    <div class="form-group">
                        <label>Jogcím (Fizetés típusa)</label>
                        <select @bind="kivalasztottTipusId" style="padding: 10px; border-radius: 6px; border: 1px solid #cbd5e1; width: 100%;">
                            @if (fizetesTipusokLista != null && fizetesTipusokLista.Any())
                            {
                                @foreach (var tipus in fizetesTipusokLista)
                                {
                                    <option value="@tipus.ID">@tipus.Megnevezes</option>
                                }
                            }
                            else
                            {
                                <option value="1">Kollégiumi díj (Alapértelmezett)</option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Fizetendő Összeg (Ft)</label>
                        <input type="number" @bind="haviDij" style="padding: 10px; border-radius: 6px; border: 1px solid #cbd5e1; width: 100%; box-sizing: border-box;" />
                    </div>
                    
                    <div class="form-row">
                        <div class="form-group half-width">
                            <label>Befizetési határidő vége</label>
                            <input type="date" @bind="befizetesiHatarido" @bind:format="yyyy-MM-dd" style="padding: 10px; border-radius: 6px; border: 1px solid #cbd5e1; width: 100%; box-sizing: border-box;" />
                        </div>
                    </div>

                    @if (mentesFolyamatban)
                    {
                        <button class="btn-submit" disabled>Generálás...</button>
                    }
                    else
                    {
                        <button class="btn-submit" @onclick="DijakKiirasaMindenkinek">Díjak generálása minden lakónak</button>
                    }
                </div>
            </div>

            <div class="card settings-card full-width">
                <div class="card-header">
                    <h2><i class="bi bi-bell"></i> Értesítések és Rendszer</h2>
                </div>
                <div class="notification-list">

                    <div class="toggle-row">
                        <div class="toggle-info">
                            <span class="toggle-title">Új hibajegy értesítés</span>
                            <span class="toggle-desc">Email küldése, ha egy lakó új karbantartási igényt ad le.</span>
                        </div>
                        <label class="switch">
                            <input type="checkbox" @bind="ui_HibaErtesites">
                            <span class="slider round"></span>
                        </label>
                    </div>

                    <div class="toggle-row">
                        <div class="toggle-info">
                            <span class="toggle-title">Késedelmes fizetés riasztás</span>
                            <span class="toggle-desc">Automatikus figyelmeztetés a lejárt tartozásokról.</span>
                        </div>
                        <label class="switch">
                            <input type="checkbox" @bind="ui_KesedelmesRiasztas">
                            <span class="slider round"></span>
                        </label>
                    </div>

                    <div class="toggle-row">
                        <div class="toggle-info">
                            <span class="toggle-title">Karbantartási mód</span>
                            <span class="toggle-desc">A diákok nem tudnak bejelentkezni, amíg a rendszer frissül.</span>
                        </div>
                        <label class="switch">
                            <input type="checkbox" @bind="ui_KarbantartasiMod">
                            <span class="slider round"></span>
                        </label>
                    </div>

                </div>
            </div>

        </div>
    </div>
}

@code {
    private bool betoltesAlatt = true;
    private bool mentesFolyamatban = false;
    private string token = "";

    // Üzenetek
    private bool sikeresMentes = false;
    private string sikerUzenet = "";
    private string hibaUzenet = "";

    // Űrlap változók a Pénzügyekhez
    private List<FizetesTipusok> fizetesTipusokLista = new();
    
    // 1-ES ID van beállítva alapértelmezettnek!
    private int kivalasztottTipusId = 1; 
    
    private decimal haviDij = 15000;
	private DateTime befizetesiHatarido = DateTime.Now.AddDays(10); // Alapértelmezett befizetési határidő vége 10 nap múlva

    // Lokális UI változók a kapcsolókhoz -> Fejlesztési lehetőségeknél van
    private bool ui_HibaErtesites = true;
    private bool ui_KesedelmesRiasztas = true;
    private bool ui_KarbantartasiMod = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

                if (string.IsNullOrEmpty(token))
                {
                    Nav.NavigateTo("/", forceLoad: true);
                    return;
                }

				// Szerepkör ellenőrzése csak adminoknak szabad hozzáférniük ehhez az oldalhoz
                var handler = new JwtSecurityTokenHandler();
                var jwtToken = handler.ReadJwtToken(token);
                var szerepkor = jwtToken.Claims.FirstOrDefault(x => x.Type == "role" || x.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role")?.Value;

                if (szerepkor != "1" && szerepkor?.ToLower() != "admin")
                {
                    Nav.NavigateTo("/", forceLoad: true);
                    return;
                }

				// Létező fizetési típusok lekérése, hogy a legördülő menüben megjelenjenek
                fizetesTipusokLista = await FizetesTipusok.GetFizetesTipusok(token) ?? new();
            }
            catch (Exception ex)
            {
                hibaUzenet = $"Hiba az ellenőrzéskor: {ex.Message}";
            }
            finally
            {
                betoltesAlatt = false;
                StateHasChanged();
            }
        }
    }

    private async Task DijakKiirasaMindenkinek()
    {
        hibaUzenet = "";
        sikeresMentes = false;
        mentesFolyamatban = true;

        try
        {
            // Lekérjük a szobabeosztásokat, hogy megtudjuk, kik az aktív lakók
            var beosztasok = await SzobaBeosztasok.GetSzobaBeosztasok(token) ?? new();

            // Kiválogatjuk az egyedi aktív UserID-kat
            var aktivLakoIdk = beosztasok
                .Where(b => b.TenylegesKikoltozes == null)
                .Select(b => b.UserID)
                .Distinct()
                .ToList();

            if (!aktivLakoIdk.Any())
            {
                hibaUzenet = "Nincsenek aktív lakók a rendszerben, nincs kinek kiírni a díjat!";
                mentesFolyamatban = false;
                return;
            }

            int sikeresenLetrehozva = 0;

            // Végigmegyünk az aktív lakókon, és mindegyiknek létrehozunk egy Pénzügyek rekordot
            foreach (var userId in aktivLakoIdk)
            {
                var ujPenzugy = new Penzugyek
                {
                    UserID = userId,
                    TipusID = kivalasztottTipusId,
                    Osszeg = haviDij,
                    Esedekesseg = befizetesiHatarido,
                    BefizetesDatum = null,
                    Statusz = "ESEDEKES"
                };

                await Penzugyek.CreatePenzugyek(ujPenzugy, token);
                sikeresenLetrehozva++;
            }

            // Kiderítjük a kiválasztott típus nevét
            string tipusNev = fizetesTipusokLista?.FirstOrDefault(t => t.ID == kivalasztottTipusId)?.Megnevezes ?? "Egyéb díj";

            sikerUzenet = $"A {tipusNev} {haviDij} Ft sikeresen kiírásra került {sikeresenLetrehozva} lakó számára!";
            sikeresMentes = true;

            // 3 mp múlva eltüntetjük a zöld üzenetet
            _ = Task.Run(async () =>
            {
                await Task.Delay(3000);
                sikeresMentes = false;
                await InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            hibaUzenet = $"Hiba a díjak generálásakor: {ex.Message}";
        }
        finally
        {
            mentesFolyamatban = false;
        }
    }
}