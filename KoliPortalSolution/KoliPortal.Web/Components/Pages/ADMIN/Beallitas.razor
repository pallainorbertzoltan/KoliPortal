@page "/beallitasok"
@layout AdminLayout

<header class="page-header text-center">
    <h1>Rendszerbeállítások</h1>
    <p>A kollégiumi portál globális beállításai és profilkezelés.</p>
</header>

<div class="content-wrapper">
    <div class="settings-grid">

        <div class="card settings-card">
            <div class="card-header">
                <h2><i class="bi bi-person-badge"></i> Saját profil</h2>
            </div>
            <div class="settings-form">
                <div class="form-group">
                    <label>Jelenlegi jelszó</label>
                    <input type="password" placeholder="********" />
                </div>
                <div class="form-group">
                    <label>Új jelszó</label>
                    <input type="password" placeholder="Új jelszó megadása" />
                </div>
                <button class="btn-submit">Jelszó frissítése</button>
            </div>
        </div>

        <div class="card settings-card">
            <div class="card-header">
                <h2><i class="bi bi-building"></i> Kollégiumi adatok</h2>
            </div>
            <div class="settings-form">
                <div class="form-group">
                    <label>Havi kollégiumi díj (Ft)</label>
                    <input type="number" value="15000" />
                </div>
                <div class="form-row">
                    <div class="form-group half-width">
                        <label>Szemeszter kezdete</label>
                        <input type="date" value="2026-02-01" />
                    </div>
                    <div class="form-group half-width">
                        <label>Szemeszter vége</label>
                        <input type="date" value="2026-06-30" />
                    </div>
                </div>
                <button class="btn-submit">Adatok mentése</button>
            </div>
        </div>

        <div class="card settings-card full-width">
            <div class="card-header">
                <h2><i class="bi bi-bell"></i> Értesítések és Rendszer</h2>
            </div>
            <div class="notification-list">

                <div class="toggle-row">
                    <div class="toggle-info">
                        <span class="toggle-title">Új hibajegy értesítés</span>
                        <span class="toggle-desc">Email küldése, ha egy lakó új karbantartási igényt ad le.</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked>
                        <span class="slider round"></span>
                    </label>
                </div>

                <div class="toggle-row">
                    <div class="toggle-info">
                        <span class="toggle-title">Késedelmes fizetés riasztás</span>
                        <span class="toggle-desc">Automatikus figyelmeztetés a lejárt tartozásokról.</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" checked>
                        <span class="slider round"></span>
                    </label>
                </div>

                <div class="toggle-row">
                    <div class="toggle-info">
                        <span class="toggle-title">Karbantartási mód</span>
                        <span class="toggle-desc">A diákok nem tudnak bejelentkezni, amíg a rendszer frissül.</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox">
                        <span class="slider round"></span>
                    </label>
                </div>

            </div>
        </div>

    </div>
</div>

