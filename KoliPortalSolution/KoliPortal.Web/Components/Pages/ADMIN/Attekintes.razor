@page "/"
@layout AdminLayout

<header class="page-header">
    <h1>Rendszer Áttekintés</h1>
    <p>Kollégiumi menedzsment központ.</p>
</header>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon purple">
            <i class="bi bi-person-check-fill icon-large"></i>
        </div>
        <div class="stat-details">
            <h3>[Aktív lakók számának helye]</h3>
            <p>Aktív Lakó</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon blue">
            <i class="bi bi-house-door-fill icon-large"></i>
        </div>
        <div class="stat-details">
            <h3>[Szabad ágy számának helye]</h3>
            <p>Szabad ágy</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon orange">
            <i class="bi bi-exclamation-triangle-fill icon-large"></i>
        </div>
        <div class="stat-details">
            <h3>[Nyitott hiba számának helye]</h3>
            <p>Nyitott Hiba</p>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon green">
            <i class="bi bi-cash-coin icon-large"></i>
        </div>
        <div class="stat-details">
            <h3>[Befizetési arány helye]</h3>
            <p>Befizetési arány</p>
        </div>
    </div>
</div>

<div class="content-grid">
    <div class="card recent-residents-card">
        <div class="card-header">
            <h2>Legújabb Lakók</h2>
            <button class="btn-outline">Lista Kezelése</button>
        </div>

        <table class="data-table">
            <thead>
                <tr>
                    <th>Név</th>
                    <th>Szoba</th>
                    <th>Státusz</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>[Név helye]</td>
                    <td>[Szoba helye]</td>
                    <td>
                        <span class="status-badge aktív">[Státusz helye]</span>
                    </td>
                </tr>
                <tr>
                    <td>[Név helye]</td>
                    <td>[Szoba helye]</td>
                    <td>
                        <span class="status-badge aktív">[Státusz helye]</span>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="card capacity-card">
        <div class="card-header">
            <h2>Szoba Kapacitás</h2>
        </div>

        <div class="capacity-list">
            <div class="capacity-item">
                <span class="floor-name">[Emelet neve helye]</span>
                <span class="floor-capacity">[Kapacitás helye (pl. 100/72 fő)]</span>
            </div>
            <div class="capacity-item">
                <span class="floor-name">[Emelet neve helye]</span>
                <span class="floor-capacity">[Kapacitás helye (pl. 100/72 fő)]</span>
            </div>
            <div class="capacity-item">
                <span class="floor-name">[Emelet neve helye]</span>
                <span class="floor-capacity">[Kapacitás helye (pl. 100/72 fő)]</span>
            </div>
        </div>
    </div>
</div>

